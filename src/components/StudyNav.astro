---
export interface Props {
  slides: Array<{ id: string; title: string }>
}

const { slides } = Astro.props
---

<nav class="study-nav" aria-label="Slide navigation">
  <ol class="study-nav-list">
    {
      slides.map((slide, index) => (
        <li class="study-nav-item">
          <a
            href={`#${slide.id}`}
            class:list={['study-nav-dot', { active: index === 0 }]}
            aria-label={`Go to: ${slide.title}`}
            data-slide-index={index}
          >
            <span class="study-nav-dot-indicator" />
            <span class="study-nav-dot-label">{slide.title}</span>
          </a>
        </li>
      ))
    }
  </ol>
</nav>

<style lang="scss">
  @use '../styles/scssVariables' as *;

  .study-nav {
    position: fixed;
    left: var(--spacing-7);
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;

    @media (width < $breakpoint-md) {
      display: none;
    }
  }

  .study-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .study-nav-item {
    display: flex;
    align-items: center;
  }

  .study-nav-dot {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    text-decoration: none;
    color: var(--study-text-muted);
    transition: color 0.2s ease;

    &:hover,
    &.active {
      color: var(--study-color);
    }
  }

  .study-nav-dot-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    flex-shrink: 0;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease;

    .study-nav-dot.active & {
      background-color: var(--study-color);
      border-color: var(--study-color);
      transform: scale(1.25);
    }
  }

  .study-nav-dot-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    pointer-events: none;

    .study-nav:hover & {
      opacity: 1;
      transform: translateX(0);
    }

    .study-nav-dot.active & {
      color: var(--study-color);
    }
  }
</style>
