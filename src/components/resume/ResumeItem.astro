---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets'

export interface Props {
  name: string
  position?: string
  dates?: string
  url?: string
  color?: string
  icon?: ImageMetadata
  class?: string
  [key: string]: any
}

const { name, position, dates, url, color, icon, class: className, ...rest } = Astro.props

const isProject = !!color
---

<div
  class:list={['resume-section resume-item', { 'resume-item--project': isProject }, className]}
  style={color ? `--item-color: ${color}` : undefined}
  {...rest}
>
  {icon && <Image src={icon} alt="" class="resume-item__icon" width="32" height="32" layout="constrained" />}
  <div class="resume-section__left">
    <h3 class="resume-item__name">{name}</h3>
    {position && <p class="resume-item__position">{position}</p>}
    {dates && <p class="resume-item__dates">{dates}</p>}
    {
      url && (
        <a href={`https://${url}`} class="resume-item__url" target="_blank" rel="noopener noreferrer">
          {url}
        </a>
      )
    }
  </div>
  <div class="resume-section__right">
    <slot />
  </div>
</div>

<style lang="scss">
  @use '../../styles/scssVariables' as *;

  .resume-item--project {
    background-color: var(--item-color);
    padding: var(--spacing-6);
  }

  .resume-item__icon {
    position: absolute;
    right: 100%;
    margin-right: var(--spacing-5);
    top: 0.875rem;
    width: 2rem;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    flex-shrink: 0;

    @media (width < $breakpoint-md) {
      top: var(--spacing-6);
      right: var(--spacing-6);
      margin-right: 0;
    }
  }

  .resume-item__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--gray-1);
    line-height: 1.3;
  }

  .resume-item__position {
    font-size: 14px;
    color: var(--gray-4);
    margin-top: 2px;
  }

  .resume-item__dates {
    font-size: 14px;
    color: var(--gray-6);
    margin-top: 2px;
  }

  .resume-item__url {
    font-size: 0.875rem;
    color: var(--gray-5);
    mix-blend-mode: multiply;
    text-decoration: none;
    margin-top: 2px;
    display: block;

    &:hover {
      text-decoration: underline;
    }
  }
</style>
