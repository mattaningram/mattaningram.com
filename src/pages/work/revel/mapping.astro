---
import StudyLayout from '@layouts/StudyLayout.astro'
import RouteNav from '@components/RouteNav.astro'
import GmapsImg from '@media/revel/mapping/gmaps-bg.png'
import HeroHeatmap from '@media/revel/mapping/HeroHeatmap.astro'
import CarTopdown from '@media/revel/mapping/revel-tesla-top.png'
import { Image } from 'astro:assets'

const slides = [
  { id: 'hero', title: 'Remapping Revel' },
  { id: 'w2-to-1099', title: 'Changing Contracts' },
  { id: 'map-migration', title: 'Map Migration' },
  { id: 'map-design-system', title: 'Map Design System' },
  { id: 'drivers', title: 'Drivers: Where & Why' },
  { id: 'visualizations', title: 'Demanding Visualizations' },
  { id: 'decisions', title: 'Key Design Decisions' },
  { id: 'failures', title: "What Didn't Work" },
  { id: 'results', title: 'Results' },
  { id: 'next', title: 'What Comes Next' },
]
---

<StudyLayout title="Remapping Revel" color="rgb(1, 185, 242)" slides={slides}>
  <RouteNav slides={slides} slot="nav" />
  <!-- Slide 1: Hero -->
  <section class="study-slide slide-hero" id="hero">
    <div class="hero-accent"></div>
    <div class="slide-inner slide-inner--centered">
      <h1 class="slide-body hero-title">Remapping Revel</h1>
      <div class="slide-body hero-meta">
        <span class="hero-role">Lead Product Designer</span>
        <span class="hero-divider"></span>
        <span class="hero-period">2022 &ndash; 2025</span>
      </div>
      <p class="slide-media hero-summary">
        I led design on creating a new mapping system across all of Revel's products and spearheaded demand heatmaps
        that helped drivers improve their earnings.
      </p>
      <div class="hero-visual">
        <img src={GmapsImg.src} alt="" class="hero-map-img" width={GmapsImg.width} height={GmapsImg.height} />
        <HeroHeatmap class="hero-heatmap" />
      </div>
    </div>
  </section>

  <!-- Slide 2: W2 to 1099 -->
  <section class="study-slide" id="w2-to-1099">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Context</p>
          <h2 class="slide-heading">Changing Contracts</h2>
          <p class="slide-body slide-subtitle">
            Revel pivoted from salaried drivers to independent contractors which significantly changed driver incentives
          </p>
        </div>
      </div>
      <div class="w2-1099-diagram">
        <div class="employment-card employment-card--w2">
          <div class="employment-card-header">
            <span class="employment-card-label">W2</span>
            <span class="employment-card-tag">Employee</span>
          </div>
          <ul class="employment-card-list">
            <li>
              <span class="employment-card-category">Pay</span>
              Hourly salary with a predictable weekly paycheck
            </li>
            <li>
              <span class="employment-card-category">Scheduling</span>
              Fixed shifts assigned and managed by Revel
            </li>
            <li>
              <span class="employment-card-category">Incentives</span>
              No direct link between rides completed and take-home pay
            </li>
          </ul>
        </div>

        <div class="employment-arrow" aria-hidden="true">
          <svg class="employment-arrow-svg" viewBox="0 0 24 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="12" y1="0" x2="12" y2="28" stroke="currentColor" stroke-width="4" stroke-linecap="round"></line>
            <polyline
              points="6,22 12,30 18,22"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"></polyline>
          </svg>
        </div>

        <div class="employment-card employment-card--1099">
          <div class="employment-card-header">
            <span class="employment-card-label">1099</span>
            <span class="employment-card-tag">Contractor</span>
          </div>
          <ul class="employment-card-list">
            <li>
              <span class="employment-card-category">Pay</span>
              Per-ride earnings plus tips and completion bonuses
            </li>
            <li>
              <span class="employment-card-category">Scheduling</span>
              Self-selected hours with full flexibility over shift times
            </li>
            <li>
              <span class="employment-card-category">Incentives</span>
              More rides per hour directly increases earnings
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 3: Map Migration -->
  <section class="study-slide slide-split slide-split--reversed" id="map-migration">
    <div class="slide-inner slide-inner--split">
      <div class="slide-media">
        <div class="media-placeholder">
          <span class="media-placeholder-label">Map comparison</span>
        </div>
      </div>
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Infrastructure</p>
          <h2 class="slide-heading">Map Migration</h2>
          <p class="slide-body slide-subtitle">
            We decided to switch from Mapbox to Google Maps for map views and location search
          </p>
        </div>
        <ul class="slide-body slide-list">
          <li>Mapbox was expensive and had outdated place data, causing poor search results for riders</li>
          <li>Google offered better pricing, traffic data, and more reliable search results</li>
          <li>Created a shared map style and component system across all products</li>
          <li>Lower cost per map load unlocked showing maps in more relevant parts of the UI</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Slide: Map Design System -->
  <section class="study-slide slide-design-system" id="map-design-system">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Infrastructure</p>
        <h2 class="slide-heading">Map Design System</h2>
        <p class="slide-body slide-subtitle">
          Opportunity to consolidate map styles and components into a single system
        </p>
      </div>
      <div class="route-designs">
        <!-- Operations -->
        <div class="route-design">
          <p class="route-design-label">Operations</p>
          <div class="route-line route-line--ops">
            <div class="route-track"></div>
            <span class="route-el route-dot route-dot--gray route-dot--lg" style="left: 2%"></span>
            <span class="route-el route-car" style="left: 22%">
              <Image src={CarTopdown} alt="" width="64" height="64" layout="constrained" />
            </span>
            <span class="route-el route-dot route-dot--blue" style="left: 52%"></span>
            <span class="route-el route-dot route-dot--blue route-dot--lg" style="left: 98%"></span>
          </div>
        </div>

        <!-- Driver / Ride Request + Traffic -->
        <div class="route-design">
          <p class="route-design-label">Driver / Ride Request + Traffic</p>
          <div class="route-line route-line--traffic">
            <div class="route-track"></div>
            <span class="route-el route-car" style="left: 3%">
              <Image src={CarTopdown} alt="" width="64" height="64" layout="constrained" />
            </span>
            <span class="route-el route-action route-action--pickup" style="left: 32%">
              <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 12V5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 2.5"
                ></path>
                <path
                  d="M3.5 7.5L7 3.5L10.5 7.5"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
            <span class="route-el route-dot route-dot--blue" style="left: 65%"></span>
            <span class="route-el route-action route-action--dropoff" style="left: 98%">
              <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M7 2V9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-dasharray="2 2.5"></path>
                <path
                  d="M3.5 6.5L7 10.5L10.5 6.5"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </div>
        </div>

        <!-- Driver / In-Ride -->
        <div class="route-design">
          <p class="route-design-label">Driver / In-Ride</p>
          <div class="route-line route-line--inride">
            <div class="route-track" style="left: 22%"></div>
            <span class="route-el route-car" style="left: 22%">
              <Image src={CarTopdown} alt="" width="64" height="64" layout="constrained" />
            </span>
            <span class="route-pin" style="left: 47%">
              <span class="route-pin-head"></span>
              <span class="route-pin-stem"></span>
            </span>
            <span class="route-el route-dot route-dot--blue route-dot--lg" style="left: 52%"></span>
            <span class="route-profile" style="left: 52%">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="8" r="3.5" stroke="white" stroke-width="2"></circle>
                <path
                  d="M6 21C6 17.134 8.68629 14 12 14C15.3137 14 18 17.134 18 21"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"></path>
              </svg>
            </span>
            <span class="route-el route-dot route-dot--gray" style="left: 78%"></span>
            <span class="route-el route-dot route-dot--gray route-dot--lg" style="left: 98%"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 4: Drivers: Where & Why -->
  <section class="study-slide slide-split" id="drivers">
    <div class="slide-inner slide-inner--split">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Research</p>
          <h2 class="slide-heading">Drivers: Where & Why</h2>
          <p class="slide-body slide-subtitle">Understanding how drivers actually make positioning decisions</p>
        </div>
        <ul class="slide-body slide-list">
          <li>Conducted driver interviews across experience levels</li>
          <li>Visited the operations team on-site to observe how managers used existing map tools</li>
          <li>Analytics confirmed supply/demand distribution data showed systemic inefficiency</li>
          <li>Pushed for investing extra dev time in the demand heatmap</li>
        </ul>
      </div>
      <div class="slide-media">
        <div class="research-items">
          <div class="slide-stagger-item research-card">
            <span class="research-card-icon">01</span>
            <span class="research-card-text">Driver interviews</span>
          </div>
          <div class="slide-stagger-item research-card">
            <span class="research-card-icon">02</span>
            <span class="research-card-text">Ops ride-alongs</span>
          </div>
          <div class="slide-stagger-item research-card">
            <span class="research-card-icon">03</span>
            <span class="research-card-text">Analytics deep-dives</span>
          </div>
          <div class="slide-stagger-item research-card">
            <span class="research-card-icon">04</span>
            <span class="research-card-text">Demand heatmap push</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 5: Demanding Visualizations -->
  <section class="study-slide slide-media-heavy" id="visualizations">
    <div class="slide-inner slide-inner--media-heavy">
      <div class="slide-media">
        <div class="media-placeholder media-placeholder--wide">
          <span class="media-placeholder-label">H3 hexagons vs neighborhood zones</span>
        </div>
      </div>
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Exploration</p>
          <h2 class="slide-heading">Demanding Visualizations</h2>
          <p class="slide-body slide-subtitle">From H3 hexagons to human-readable neighborhood zones</p>
        </div>
        <ul class="slide-body slide-list">
          <li>The data team switched to Uber's open source H3 hexagonal spatial indexing for higher-fidelity data</li>
          <li>Direct hex-demand data added too much visual noise and made neighborhoods hard to read</li>
          <li>Translated H3 data back to familiar neighborhood zones colored at different intensities</li>
          <li>Experiment: adjusting demand relative to driver zone was perceived as confusing</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Slide 6: Key Design Decisions -->
  <section class="study-slide slide-decisions" id="decisions">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Design</p>
        <h2 class="slide-heading">Key Design Decisions</h2>
        <p class="slide-body slide-subtitle decisions-subtitle">
          Three decisions that made the heatmap trustworthy and usable while driving
        </p>
      </div>
      <div class="decision-cards">
        <div class="slide-stagger-item decision-card">
          <div class="decision-card-number">01</div>
          <h3 class="decision-card-title">Absolute Demand</h3>
          <p class="decision-card-body">
            Absolute demand felt stable and trustworthy; relative demand felt unpredictable and was abandoned after
            driver testing
          </p>
        </div>
        <div class="slide-stagger-item decision-card">
          <div class="decision-card-number">02</div>
          <h3 class="decision-card-title">Travel-Time Weighted</h3>
          <p class="decision-card-body">
            Factored in real-time traffic so a nearby medium-demand zone could outrank a distant high-demand one
          </p>
        </div>
        <div class="slide-stagger-item decision-card">
          <div class="decision-card-number">03</div>
          <h3 class="decision-card-title">Update Cadence</h3>
          <p class="decision-card-body">
            Minute-by-minute updates were too distracting while driving; 10-minute refreshes balanced freshness with
            calm
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 7: What Didn't Work -->
  <section class="study-slide slide-split slide-failure" id="failures">
    <div class="slide-inner slide-inner--split">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Retrospective</p>
          <h2 class="slide-heading">What Didn't Work</h2>
          <p class="slide-body slide-subtitle">The amenities map</p>
        </div>
        <ul class="slide-body slide-list">
          <li>Driver interviews flagged a genuine pain: difficulty finding parking and restrooms during long shifts</li>
          <li>Built an amenities map layer surfacing rideshare-friendly parking and public restrooms</li>
          <li>Analytics showed the layer was barely used; data didn't reflect real-time availability</li>
          <li>Takeaway: a feature solving a real problem still fails without reliable underlying data</li>
        </ul>
      </div>
      <div class="slide-media">
        <div class="media-placeholder media-placeholder--muted">
          <span class="media-placeholder-label">Amenities map</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 8: Results -->
  <section class="study-slide slide-results" id="results">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Outcomes</p>
        <h2 class="slide-heading">Results</h2>
        <p class="slide-body slide-subtitle results-subtitle">More efficient drivers, happier passengers</p>
      </div>
      <div class="stats-grid">
        <div class="slide-stagger-item stat-card">
          <span class="stat-number">+XX%</span>
          <span class="stat-label">Driver revenue per hour increase, strongest gains among newer drivers</span>
        </div>
        <div class="slide-stagger-item stat-card">
          <span class="stat-number">&minus;XX min</span>
          <span class="stat-label">Passenger wait time decrease as driver distribution improved</span>
        </div>
        <div class="slide-stagger-item stat-card">
          <span class="stat-number">High</span>
          <span class="stat-label">Heatmap adoption among new drivers, tapered as they learned patterns</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 9: What Comes Next -->
  <section class="study-slide slide-next" id="next">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Future</p>
        <h2 class="slide-heading">What Comes Next</h2>
        <p class="slide-body slide-subtitle">Taking advantage of other data to further enhance the map experience</p>
      </div>
      <div class="next-items">
        <div class="slide-stagger-item next-card">
          <span class="next-card-number">01</span>
          <div>
            <h3 class="next-card-title">Event Demand Alerts</h3>
            <p class="next-card-body">
              Integrate public event schedules to surface upcoming demand spikes before they happen
            </p>
          </div>
        </div>
        <div class="slide-stagger-item next-card">
          <span class="next-card-number">02</span>
          <div>
            <h3 class="next-card-title">Street View Preview</h3>
            <p class="next-card-body">
              Drivers and riders approaching a drop-off can preview the location to confirm they're in the right place
            </p>
          </div>
        </div>
        <div class="slide-stagger-item next-card">
          <span class="next-card-number">03</span>
          <div>
            <h3 class="next-card-title">Calendar Integration</h3>
            <p class="next-card-body">Suggest upcoming appointments as destinations via Google Calendar</p>
          </div>
        </div>
        <div class="slide-stagger-item next-card">
          <span class="next-card-number">04</span>
          <div>
            <h3 class="next-card-title">Advanced Data Tools</h3>
            <p class="next-card-body">Enhance the data team's visualization and prediction capabilities</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</StudyLayout>

<style lang="scss">
  @use '../../../styles/scssVariables' as *;

  // ========================================
  // Shared slide inner layouts
  // ========================================

  .slide-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }

  .slide-inner--centered {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-12);
  }

  .slide-inner--split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-14);
    align-items: center;

    @media (width < $breakpoint-lg) {
      grid-template-columns: 1fr;
      gap: var(--spacing-8);
    }
  }

  .slide-inner--media-heavy {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--spacing-14);
    align-items: center;

    @media (width < $breakpoint-lg) {
      grid-template-columns: 1fr;
      gap: var(--spacing-8);
    }
  }

  .slide-split--reversed .slide-inner--split {
    direction: rtl;

    > * {
      direction: ltr;
    }

    @media (width < $breakpoint-lg) {
      direction: ltr;
    }
  }

  // ========================================
  // Typography
  // ========================================

  .slide-text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .slide-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--study-heading);
  }

  .slide-header {
    padding-left: var(--spacing-7);
    display: flex;
    flex-direction: column;
  }

  .slide-section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--study-color);
    line-height: 1.4;
  }

  .slide-subtitle {
    max-width: 52ch;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.6;
    color: var(--study-text-muted);
    font-weight: 500;
    margin-top: var(--spacing-8);
  }

  .slide-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    margin-top: var(--spacing-5);

    li {
      font-size: clamp(0.9rem, 1.2vw, 1rem);
      line-height: 1.6;
      color: var(--study-text);
      padding-left: var(--spacing-7);
      position: relative;

      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0.65em;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--study-color);
        opacity: 0.75;
      }
    }
  }

  // ========================================
  // Media placeholders
  // ========================================

  .media-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--study-bg-alt);
    border: 1.5px dashed var(--study-border);
    border-radius: 12px;
    display: grid;
    place-content: center;

    &--wide {
      aspect-ratio: 16 / 9;
    }

    &--muted {
      opacity: 0.5;
    }
  }

  .media-placeholder-label {
    font-size: 0.8rem;
    color: var(--study-text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  // ========================================
  // Slide 2: W2 to 1099 diagram
  // ========================================

  .w2-1099-diagram {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    gap: var(--spacing-10);
    width: 100%;

    @media (width < $breakpoint-md) {
      flex-direction: column;
    }
  }

  .employment-card {
    flex: 1;
    border: 1.5px solid var(--study-border);
    border-radius: 12px;
    overflow: hidden;

    &--w2 {
      opacity: 0.75;
      border-style: dashed;
      background-color: var(--study-bg-alt);
    }

    &--1099 {
      border-color: var(--study-color);
      background-color: var(--study-color);
    }
  }

  .employment-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding: var(--spacing-7) var(--spacing-8) var(--spacing-6);
  }

  .employment-card-label {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--study-heading);
    letter-spacing: -0.01em;

    .employment-card--1099 & {
      color: #fff;
    }
  }

  .employment-card-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
    border: 1px solid #aaa;
    border-radius: 4px;
    padding: 2px 6px;

    .employment-card--1099 & {
      color: rgba(255, 255, 255, 0.85);
      border-color: rgba(255, 255, 255, 0.4);
      background-color: rgba(255, 255, 255, 0.15);
    }
  }

  .employment-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;

    li {
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--study-heading);
      display: grid;
      grid-template-columns: 5.5rem 1fr;
      gap: var(--spacing-6);
      align-items: baseline;
      border-top: 1px dashed var(--study-border);
      padding: var(--spacing-4) var(--spacing-8);

      .employment-card--1099 & {
        color: #fff;
        border-top-style: solid;
        border-top-color: rgba(255, 255, 255, 0.2);
      }
    }
  }

  .employment-card-category {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #666;

    .employment-card--1099 & {
      color: rgba(255, 255, 255, 0.7);
    }
  }

  .employment-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--study-color);
    padding: 0 var(--spacing-1);
    flex-shrink: 0;

    @media (width < $breakpoint-md) {
      padding: var(--spacing-1) 0;
    }
  }

  .employment-arrow-svg {
    width: 20px;
    height: 32px;
    animation: arrow-bounce-h 1.6s ease-in-out infinite;

    @media (width < $breakpoint-md) {
      animation-name: arrow-bounce;
    }
  }

  @keyframes arrow-bounce {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: translateY(4px);
      opacity: 1;
    }
  }

  @keyframes arrow-bounce-h {
    0%,
    100% {
      transform: rotate(-90deg) translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: rotate(-90deg) translateY(4px);
      opacity: 1;
    }
  }

  // ========================================
  // Slide 1: Hero
  // ========================================

  .slide-hero {
    align-items: flex-end;
    padding-bottom: 0;

    .hero-accent {
      position: absolute;
      width: 50vmin;
      height: 50vmin;
      border-radius: 50%;
      background: radial-gradient(circle, hsl(from var(--study-color) h s l / 0.07) 0%, transparent 70%);
      pointer-events: none;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .slide-inner {
      position: relative;
      z-index: 1;
    }

    @media (width < $breakpoint-md) {
      padding-bottom: var(--spacing-12);
    }
  }

  .hero-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--study-color);
    margin-bottom: var(--spacing-4);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.75rem, 6vw, 5rem);
    font-weight: 500;
    line-height: 1.05;
    color: var(--study-heading);
    letter-spacing: -0.02em;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    margin-top: var(--spacing-6);
