  .route-dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;

    &--gray {
      background: white;
      border: 6px solid #c4c9d1;
    }

    &--blue {
      background: white;
      border: 6px solid #2874f0;
    }

    &--lg {
      width: 28px;
      height: 28px;
    }

    &--sm {
      width: 20px;
      height: 20px;
    }
