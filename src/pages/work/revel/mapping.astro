    margin-bottom: var(--spacing-2);
  }

  .route-line {
    position: relative;
    height: 72px;
    width: 100%;
    overflow: visible;
  }

  .route-track {
    position: absolute;
    top: 50%;
    left: 14px;
    right: 14px;
    height: 6px;
    transform: translateY(-50%);
    border-radius: 3px;
  }

  .route-el {
    position: absolute;
    top: 50%;
