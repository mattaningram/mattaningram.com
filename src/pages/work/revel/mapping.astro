  .route-car {
    width: 64px;
    height: 64px;

    img {
      transform: rotate(90deg);
    }
  }

  .route-action {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: grid;
    place-content: center;

    svg {
      width: 14px;
      height: 14px;
    }

    &--pickup {
      background: #10b981;
    }

    &--dropoff {
      background: #f97316;
    }
  }

  .route-line--ops .route-track {
    background: linear-gradient(to right, #c4c9d1 22%, #2874f0 22%, #2874f0 52%, #8fb8f8 52%);
  }

  .route-line--traffic .route-track {
    background: linear-gradient(
      to right,
      #2874f0 0%,
      #2874f0 12%,
      #db2777 18%,
      #db2777 22%,
      #2874f0 28%,
      #2874f0 52%,
      #f59e0b 58%,
      #f59e0b 78%,
      #2874f0 84%
    );
  }

  .route-line--inride .route-track {
    background: linear-gradient(to right, #2874f0 52%, #c4c9d1 52%);
  }

  .route-pin {
    position: absolute;
    bottom: 64%;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 1;
  }

  .route-pin-head {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #10b981;
  }

  .route-pin-stem {
    width: 2px;
    height: 14px;
    background: #10b981;
  }

  .route-profile {
    position: absolute;
    top: 50%;
    translate: -50% 0;
    margin-top: 6px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #104f91;
    box-shadow: 0 0 0 18px rgba(79, 155, 248, 0.15);
    display: grid;
    place-content: center;
    z-index: 1;

    svg {
      width: 14px;
      height: 14px;
    }
  }

  // Animation initial states
  .slide-design-system .route-design-label {
    opacity: 0;
  }

  .slide-design-system .route-track {
    clip-path: inset(0 100% 0 0);
  }

  .slide-design-system .route-el,
  .slide-design-system .route-pin,
  .slide-design-system .route-profile {
    opacity: 0;
  }

  // ========================================
  // Slide 4: Research cards
  // ========================================

  .research-items {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .research-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-5);
    padding: var(--spacing-5) var(--spacing-6);
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 10px;
    transition: border-color 0.2s ease;

    &:hover {
      border-color: var(--study-color);
    }
  }

  .research-card-icon {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--study-color);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: grid;
    place-content: center;
    border-radius: 50%;
    background: hsl(from var(--study-color) h s l / 0.1);
  }

  .research-card-text {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--study-text);
  }

  // ========================================
  // Slide 6: Decision cards
  // ========================================

  .decisions-subtitle {
    margin-bottom: var(--spacing-8);
  }

  .decision-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
    width: 100%;

    @media (width < $breakpoint-md) {
      grid-template-columns: 1fr;
    }
  }

  .decision-card {
    text-align: left;
    padding: var(--spacing-8);
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .decision-card-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--study-color);
    letter-spacing: 0.05em;
  }

  .decision-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--study-heading);
  }

  .decision-card-body {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--study-text-muted);
  }

  // ========================================
  // Slide 7: Failure
  // ========================================

  .slide-failure {
    background-color: hsl(from var(--study-bg) h s l / 0.97);
  }

  // ========================================
  // Slide 8: Results / Stats
  // ========================================

  .results-subtitle {
    margin-bottom: var(--spacing-8);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-6);
    width: 100%;

    @media (width < $breakpoint-md) {
      grid-template-columns: 1fr;
    }
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    padding: var(--spacing-8);
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 12px;
  }

  .stat-number {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    color: var(--study-color);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--study-text-muted);
  }

  // ========================================
  // Slide 9: What Comes Next
  // ========================================

  .next-items {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
    width: 100%;
    max-width: 640px;
    margin-top: var(--spacing-6);
  }

  .next-card {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-5);
    text-align: left;
    padding: var(--spacing-5) var(--spacing-6);
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 10px;
  }

  .next-card-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--study-color);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: grid;
    place-content: center;
    border-radius: 50%;
    background: hsl(from var(--study-color) h s l / 0.1);
    margin-top: 2px;
  }

  .next-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--study-heading);
    margin-bottom: var(--spacing-1);
  }

  .next-card-body {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--study-text-muted);
  }
</style>

<script>
  import { animate, stagger, inView } from 'motion'

  const heroSection = document.getElementById('hero')
  if (heroSection) {
    let fired = false

    inView(
      heroSection,
      () => {
        if (fired) return
        fired = true

        const mapImg = heroSection.querySelector('.hero-map-img') as HTMLElement
        const zones = heroSection.querySelectorAll('.hero-heatmap-zones path')
        const dots = heroSection.querySelectorAll('.hero-route-dot')
        const mainRoute = heroSection.querySelector('.hero-route-main') as SVGPathElement
        const progressRoute = heroSection.querySelector('.hero-route-progress') as SVGPathElement

        if (!mapImg || !mainRoute || !progressRoute) return

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

        if (reducedMotion) {
          const heroVisual = heroSection.querySelector('.hero-visual') as HTMLElement
          if (heroVisual) {
            heroVisual.style.opacity = '1'
            heroVisual.style.translate = 'none'
          }
          ;(mapImg as HTMLElement).style.opacity = '1'
          zones.forEach((z) => ((z as HTMLElement).style.opacity = '1'))
          dots.forEach((d) => {
            ;(d as HTMLElement).style.opacity = '1'
            ;(d as HTMLElement).style.scale = '1'
          })
          mainRoute.style.strokeDashoffset = '0'
          progressRoute.style.strokeDashoffset = '0'
          const lb = 'color(display-p3 0.2314 0.7843 0.9882)'
          const ds = heroSection.querySelector('.hero-route-dot-progress-start') as SVGCircleElement | null
          const de = heroSection.querySelector('.hero-route-dot-progress-end') as SVGCircleElement | null
          if (ds) ds.style.stroke = lb
          if (de) de.style.stroke = lb
          return
        }

        // Measure actual path lengths and set initial hidden state
        const mainLength = mainRoute.getTotalLength()
        mainRoute.style.strokeDasharray = `${mainLength}`
        mainRoute.style.strokeDashoffset = `${mainLength}`

        const progressLength = progressRoute.getTotalLength()
        progressRoute.style.strokeDasharray = `${progressLength}`
        progressRoute.style.strokeDashoffset = `${progressLength}`

        const easing: [number, number, number, number] = [0.22, 1, 0.36, 1]

        // 0. Hero visual slides up and fades in
        const heroVisual = heroSection.querySelector('.hero-visual') as HTMLElement
        if (heroVisual) {
          animate(
            heroVisual,
            { opacity: [0, 1], translate: ['0 40px', '0 0px'] },
            { duration: 0.7, easing: [0.22, 1, 0.36, 1] },
          )
        }

        // 1. Map image fades in
        animate(mapImg, { opacity: [0, 1] }, { duration: 0.7, delay: 0.2, easing: 'ease-out' })

        // 2. Heatmap zones staggered in reverse - set style.opacity directly since Motion
        // animates SVG opacity as a presentation attribute, not a CSS property
        const zoneArray = Array.from(zones).reverse()
        zoneArray.forEach((z, i) => {
          setTimeout(
            () => {
              ;(z as HTMLElement).style.opacity = '1'
            },
            500 + i * 100,
          )
        })

        const dotProgressStart = heroSection.querySelector('.hero-route-dot-progress-start') as SVGCircleElement | null
        const dotProgressEnd = heroSection.querySelector('.hero-route-dot-progress-end') as SVGCircleElement | null
        const lightBlue = 'color(display-p3 0.2314 0.7843 0.9882)'

        const showDot = (d: Element) => {
          ;(d as HTMLElement).style.opacity = '1'
          ;(d as HTMLElement).style.scale = '1'
        }

        // 3. Route dots pop in as the main route line reaches each position.
        // dot[0] (start, cx=420): route begins here at 2150ms
        // dot[2] (cx=278): route reaches ~32% spatially; with ease-out that's ~15% temporally → ~2350ms
        // dot[1] (route end, cx=701): route nearly arrives at ~3300ms
        setTimeout(() => showDot(dots[0]), 2150)
        setTimeout(() => showDot(dots[2]), 2350)
        setTimeout(() => showDot(dots[1]), 3300)

        // 4 & 5. Add transitions after initial values are committed so the browser
        // doesn't animate the CSS→inline value change. Then draw in via setTimeout.
        requestAnimationFrame(() => {
          mainRoute.style.transition = `stroke-dashoffset 1.3s cubic-bezier(0.22, 1, 0.36, 1)`
          progressRoute.style.transition = `stroke-dashoffset 0.65s cubic-bezier(0.22, 1, 0.36, 1)`

          setTimeout(() => {
            mainRoute.style.strokeDashoffset = '0'
          }, 2150)

          // Progress line starts at 3450ms; turn start dot light blue 250ms early
          setTimeout(() => {
            if (dotProgressStart) dotProgressStart.style.stroke = lightBlue
          }, 3200)

          setTimeout(() => {
            progressRoute.style.strokeDashoffset = '0'
          }, 3450)

          // Progress line ends at 4100ms; turn end dot light blue 200ms early
          setTimeout(() => {
            if (dotProgressEnd) dotProgressEnd.style.stroke = lightBlue
          }, 3900)
        })
      },
      { amount: 0.25 },
    )
  }

  // ==========================================
  // Map Design System – route line animations
  // ==========================================
  const dsSection = document.getElementById('map-design-system')
  if (dsSection) {
    let dsFired = false

    inView(
      dsSection,
      () => {
        if (dsFired) return
        dsFired = true

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        const designs = dsSection.querySelectorAll('.route-design')

        if (reducedMotion) {
          dsSection
            .querySelectorAll('.route-design-label, .route-el, .route-track, .route-pin, .route-profile')
            .forEach((el) => {
              ;(el as HTMLElement).style.opacity = '1'
              ;(el as HTMLElement).style.scale = '1'
            })
          dsSection.querySelectorAll('.route-track').forEach((el) => {
            ;(el as HTMLElement).style.clipPath = 'inset(0 0% 0 0)'
          })
          return
        }

        const easing: [number, number, number, number] = [0.22, 1, 0.36, 1]
        const trackDuration = 0.7
        const rowStagger = 0.45

        designs.forEach((design, i) => {
          const base = i * rowStagger

          // Label fades in
          const label = design.querySelector('.route-design-label') as HTMLElement
          if (label) {
            animate(
              label,
              { opacity: [0, 1], y: [8, 0] } as any,
              {
                duration: 0.3,
                delay: base,
                easing,
              } as any,
            )
          }

          // Track draws in left → right via clip-path
          const track = design.querySelector('.route-track') as HTMLElement
          if (track) {
            animate(
              track,
              { clipPath: ['inset(0 100% 0 0)', 'inset(0 0% 0 0)'] },
              { duration: trackDuration, delay: base + 0.1, easing },
            )
          }

          // Cars slide in from left
          const cars = design.querySelectorAll('.route-car')
          cars.forEach((car) => {
            const htmlEl = car as HTMLElement
            const leftPct = htmlEl.style.left ? parseFloat(htmlEl.style.left) / 100 : 0.5
            const elementDelay = base + 0.1 + leftPct * trackDuration

            animate(
              htmlEl,
              { opacity: [0, 1], x: [-20, 0] } as any,
              {
                duration: 0.4,
                delay: elementDelay,
                easing,
              } as any,
            )
          })

          // Other elements scale + fade
          const elements = design.querySelectorAll('.route-el:not(.route-car), .route-pin, .route-profile')
          elements.forEach((el) => {
            const htmlEl = el as HTMLElement
            const leftPct = htmlEl.style.left ? parseFloat(htmlEl.style.left) / 100 : 0.5
            const elementDelay = base + 0.1 + leftPct * trackDuration

            animate(
              htmlEl,
              { opacity: [0, 1], scale: [0, 1] } as any,
              {
                duration: 0.35,
                delay: elementDelay,
                easing,
              } as any,
            )
          })
        })
      },
      { amount: 0.25 },
    )
  }
</script>
