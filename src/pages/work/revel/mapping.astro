---
import StudyLayout from '@layouts/StudyLayout.astro'
import RouteNav from '@components/RouteNav.astro'
import GmapsImg from '@media/revel/mapping/gmaps-bg.png'

const slides = [
  { id: 'hero', title: 'Remapping Revel' },
  { id: 'w2-to-1099', title: 'W2 to 1099' },
  { id: 'map-migration', title: 'Map Migration' },
  { id: 'drivers', title: 'Drivers: Where & Why' },
  { id: 'visualizations', title: 'Demanding Visualizations' },
  { id: 'decisions', title: 'Key Design Decisions' },
  { id: 'failures', title: "What Didn't Work" },
  { id: 'results', title: 'Results' },
  { id: 'next', title: 'What Comes Next' },
]
---

<StudyLayout title="Remapping Revel" color="rgb(1, 185, 242)" slides={slides}>
  <RouteNav slot="nav" slides={slides} />

  <!-- Slide 1: Hero -->
  <section class="study-slide slide-hero" id="hero">
    <div class="hero-accent"></div>
    <div class="slide-inner slide-inner--centered">
      <h1 class="slide-body hero-title">Remapping Revel</h1>
      <div class="slide-body hero-meta">
        <span class="hero-role">Lead Product Designer</span>
        <span class="hero-divider"></span>
        <span class="hero-period">2022 &ndash; 2025</span>
      </div>
      <p class="slide-media hero-summary">
        I led design on creating a new mapping system across all of Revel's products and spearheaded demand heatmaps
        that helped drivers improve their earnings.
      </p>
      <div class="hero-visual">
        <img
          src={GmapsImg.src}
          alt=""
          class="hero-map-img"
          width={GmapsImg.width}
          height={GmapsImg.height}
        />
