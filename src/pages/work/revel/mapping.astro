  <!-- Slide 5: Demanding Visualizations -->
  <section class="study-slide slide-media-heavy" id="visualizations">
    <div class="slide-inner slide-inner--media-heavy">
      <div class="slide-media">
        <div class="media-placeholder media-placeholder--wide">
          <span class="media-placeholder-label">H3 hexagons vs neighborhood zones</span>
        </div>
      </div>
      <div class="slide-text">
        <div class="slide-header-group">
          <p class="slide-section-label slide-body">Visualization</p>
          <h2 class="slide-heading">Demanding Visualizations</h2>
        </div>
        <p class="slide-body slide-subtitle">From H3 hexagons to human-readable neighborhood zones</p>
        <ul class="slide-body slide-list">
          <li>The data team switched to Uber's open source H3 hexagonal spatial indexing for higher-fidelity data</li>
          <li>Direct hex-demand data added too much visual noise and made neighborhoods hard to read</li>
          <li>Translated H3 data back to familiar neighborhood zones colored at different intensities</li>
          <li>Experiment: adjusting demand relative to driver zone was perceived as confusing</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Slide 6: Key Design Decisions -->
  <section class="study-slide slide-decisions" id="decisions">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header-group">
        <p class="slide-section-label slide-body">Design</p>
