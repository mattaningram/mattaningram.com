<script>
  const slider = document.querySelector('[data-comparison-slider]') as HTMLElement | null
  if (slider) {
    const uiSide = slider.querySelector('.comparison-side--ui') as HTMLElement
    const handle = slider.querySelector('.comparison-handle') as HTMLElement
    let isDragging = false

    function updatePosition(clientX: number) {
      const rect = slider!.getBoundingClientRect()
      const x = Math.max(0, Math.min(clientX - rect.left, rect.width))
      const percent = (x / rect.width) * 100
      uiSide.style.setProperty('--clip-position', `${percent}%`)
      handle.style.setProperty('--handle-position', `${percent}%`)
    }

    slider.addEventListener('pointerdown', (e) => {
      isDragging = true
      slider!.setPointerCapture(e.pointerId)
      updatePosition(e.clientX)
    })

    slider.addEventListener('pointermove', (e) => {
      if (!isDragging) return
      updatePosition(e.clientX)
    })

    slider.addEventListener('pointerup', () => {
      isDragging = false
    })

    slider.addEventListener('pointercancel', () => {
      isDragging = false
    })
  }
</script>

<script>
  import { animate, stagger, inView } from 'motion'

  // Design Exploration: stagger in each item (media + card)
  inView(
    '#exploration',
    () => {
      const items = document.querySelectorAll<HTMLElement>('#exploration .exploration-item')
      animate(
        items,
        { opacity: [0, 1], y: [40, 0] },
        { delay: stagger(0.12), duration: 0.5, easing: [0.25, 0.1, 0.25, 1] },
      )
    },
    { once: true },
  )

  // Fewer clicks chart: animate between before/after states
  const fewerClicksChart = document.querySelector('[data-fewer-clicks-chart]')
  if (fewerClicksChart) {
    const bars = fewerClicksChart.querySelectorAll<HTMLElement>('.chart-bar[data-from]')
    const inners = fewerClicksChart.querySelectorAll<HTMLElement>('.chart-bar-inner[data-from]')
    let showingAfter = false

    function toggleState() {
      showingAfter = !showingAfter
      bars.forEach((bar) => {
        const val = showingAfter ? bar.dataset.to : bar.dataset.from
        bar.style.setProperty('--h', val!)
      })
      inners.forEach((inner) => {
        const val = showingAfter ? inner.dataset.to : inner.dataset.from
        inner.style.setProperty('--inner-h', val!)
      })
    }

    // Add transition to bars
    bars.forEach((bar) => {
      bar.style.transition = 'height 1s ease-in-out'
    })
    inners.forEach((inner) => {
      inner.style.transition = 'height 1s ease-in-out'
    })

    setInterval(toggleState, 2500)
  }
</script>
