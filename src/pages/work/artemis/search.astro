---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import StudyLayout from '@layouts/StudyLayout.astro'
import StudyNav from '@components/StudyNav.astro'
import smallFarm from '../../../media/artemis/search/artemis-small-farm.jpg'
import enterpriseFarm from '../../../media/artemis/search/artemis-enterprise-farm.jpg'
import farmVisit from '../../../media/artemis/search/artemis-farm-visit.jpeg'
import artemisPages from '../../../media/artemis/search/artemis-pages.png'
import searchWidgets from '../../../media/artemis/search/artemis-search-widgets.png'
const farmData = await import('../../../data/artemis-farm-data.json')

function highlightJson(obj: unknown): string {
  const raw = JSON.stringify(obj, null, 2)
  return raw.replace(
    /("(?:\\.|[^"\\])*")\s*(:)?|(\b\d+\.?\d*\b)|(true|false|null)/g,
    (match, str, colon, num, bool) => {
      if (str && colon) return `<span class="json-key">${str}</span>:`
      if (str) return `<span class="json-string">${str}</span>`
      if (num) return `<span class="json-number">${num}</span>`
      if (bool) return `<span class="json-bool">${bool}</span>`
      return match
    },
  )
}

const dataColumns = [
  { label: 'Zones', data: farmData.zones.slice(0, 4) },
  { label: 'Crop Batches', data: farmData.cropBatches.slice(0, 4) },
  { label: 'Shipments', data: farmData.shipments.slice(0, 3) },
  { label: 'Reports', data: farmData.reports.slice(0, 4) },
]

const slides = [
  { id: 'hero', title: 'Finding Anything' },
  { id: 'scaling', title: 'Small to Big Farm' },
  { id: 'design', title: 'The Old Search' },
  { id: 'research', title: 'Understanding the Problem' },
  { id: 'data', title: 'Scoping the Data' },
  { id: 'exploration', title: 'Design Exploration' },
  { id: 'results', title: 'Results' },
  { id: 'next', title: 'What Comes Next' },
]
---

<StudyLayout title="Artemis Search" color="rgb(255, 64, 22)" slides={slides}>
  <StudyNav slides={slides} slot="nav" />

  <!-- Slide 1: Hero -->
  <section class="study-slide slide-hero" id="hero">
    <div class="slide-inner slide-inner--centered">
      <div class="hero-visual">
        <div class="hero-search-wrapper">
          <div class="hero-search-icons">
            <Icon name="artemis/zone" class="hero-orbit-icon" style="--ring-x: -280px; --ring-y: -130px; --delay: 4s" />
            <Icon
              name="artemis/profile"
              class="hero-orbit-icon"
              style="--ring-x: 240px; --ring-y: -160px; --delay: 0s"
            />
            <Icon
              name="artemis/document"
              class="hero-orbit-icon"
              style="--ring-x: 300px; --ring-y: 60px; --delay: 7s"
            />
            <Icon
              name="artemis/chart"
              class="hero-orbit-icon"
              style="--ring-x: -310px; --ring-y: 80px; --delay: 2s"
            />
            <Icon
              name="artemis/task"
              class="hero-orbit-icon"
              style="--ring-x: 160px; --ring-y: 170px; --delay: 5s"
            />
            <Icon name="artemis/split" class="hero-orbit-icon" style="--ring-x: -60px; --ring-y: -180px; --delay: 1s" />
            <Icon
              name="artemis/nutrients"
              class="hero-orbit-icon"
              style="--ring-x: 320px; --ring-y: -80px; --delay: 8s"
            />
            <Icon name="artemis/mail" class="hero-orbit-icon" style="--ring-x: -190px; --ring-y: 150px; --delay: 3s" />
            <Icon name="artemis/image" class="hero-orbit-icon" style="--ring-x: 100px; --ring-y: -180px; --delay: 6s" />
            <Icon
              name="artemis/harvest"
              class="hero-orbit-icon"
              style="--ring-x: -320px; --ring-y: -60px; --delay: 9s"
            />
            <Icon
              name="artemis/calendar"
              class="hero-orbit-icon"
              style="--ring-x: 250px; --ring-y: 130px; --delay: 10s"
            />
          </div>
          <div class="hero-search-bar">
            <svg
              class="hero-search-icon"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
        </div>
      </div>
      <div class="slide-header">
        <h1 class="slide-body hero-title">Farm Finding</h1>
        <div class="slide-body hero-meta">
          <span class="hero-role">Lead Product Designer</span>
          <span class="hero-divider"></span>
          <span class="hero-period">2018 &ndash; 2021</span>
        </div>
        <p class="slide-media hero-summary">
          I led the redesign of search across Artemis's platform as we scaled from small indoor farms to enterprise
          operations nationwide. The new contextual search experience became the most used feature in the app within
          weeks of shipping.
        </p>
      </div>
    </div>
  </section>

  <!-- Slide 2: Small Farm to Big Farm -->
  <section class="study-slide" id="scaling">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Context</p>
          <h2 class="slide-heading">Small Farm to Big Farm</h2>
          <p class="slide-body slide-subtitle">
            Artemis scaled from local indoor farms to massive enterprise operations around the world, changing the scope
            of features, data, and users we needed to address.
          </p>
        </div>
      </div>
      <div class="scaling-cards">
        <div class="slide-stagger-item study-card study-card--dashed scaling-card scaling-card--before">
          <div class="study-card-header">
            <span class="scaling-card-label">Before</span>
            <span class="study-card-tag">Small farms</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Scale</span>
              Small scale indoor or container farms
            </li>
            <li>
              <span class="study-card-category">Users</span>
              Site managers and growers
            </li>
            <li>
              <span class="study-card-category">Data</span>
              Tasks, Crop Schedules, Sensors
            </li>
          </ul>
          <div class="scaling-card-image">
            <Image src={smallFarm} width={600} alt="Small indoor farm" layout="constrained" fit="cover" />
          </div>
        </div>

        <div class="scaling-arrow" aria-hidden="true">
          <svg class="scaling-arrow-svg" viewBox="0 0 24 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="12" y1="0" x2="12" y2="28" stroke="currentColor" stroke-width="4" stroke-linecap="round"></line>
            <polyline
              points="6,22 12,30 18,22"
              stroke="currentColor"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"></polyline>
          </svg>
        </div>

        <div class="slide-stagger-item study-card study-card--filled scaling-card scaling-card--after">
          <div class="study-card-header">
            <span class="scaling-card-label">After</span>
            <span class="study-card-tag">Enterprise</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Scale</span>
              100+ acre enterprise indoor and outdoor farms worldwide
            </li>
            <li>
              <span class="study-card-category">Users</span>
              Farm owners, site managers, team leaders, laborers, etc.
            </li>
            <li>
              <span class="study-card-category">Data</span>
              Tasks, Labor, Inventory, Crop Management, Sensors, Reports, Compliance
            </li>
          </ul>
          <div class="scaling-card-image">
            <Image src={enterpriseFarm} width={600} alt="Enterprise farm operation" layout="constrained" fit="cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 3: The Old Search -->
  <section class="study-slide" id="design">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Before</p>
          <h2 class="slide-heading">The Old Search</h2>
          <p class="slide-body slide-subtitle">
            A hold over from the early days of the product that was no longer appropiate for our new scale of data and
            client needs
          </p>
        </div>
      </div>
      <div class="old-search-layout">
        <div class="slide-stagger-item study-card study-card--dashed old-search-card">
          <div class="study-card-header">
            <span class="research-method-label">Search v1</span>
            <span class="study-card-tag">Existing</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Mechanism</span>
              A simple text match across farm item names and ids, without context, filtering, or ranking
            </li>
            <li>
              <span class="study-card-category">Experience</span>
              No realtime results while typing and results not stored to URL to allow for bookmarking
            </li>
            <li>
              <span class="study-card-category">Problem</span>
              As the platform grew, results became a wall of undifferentiated links with no way to tell what type of thing
              you were looking at
            </li>
          </ul>
        </div>
        <video class="old-search-video" autoplay loop muted playsinline>
          <source src="/assets/videos/artemis/artemis-old-search.webm" type="video/webm" />
        </video>
      </div>
    </div>
  </section>

  <!-- Slide 4: Understanding the Problem -->
  <section class="study-slide" id="research">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Research</p>
          <h2 class="slide-heading">Understanding the Problem</h2>
          <p class="slide-body slide-subtitle">
            Field research, sales feedback, and analytics made it clear search and navigation would have to be
            redesigned to address this new scale
          </p>
        </div>
      </div>
      <div class="research-grid">
        <div class="slide-stagger-item study-card study-card--dashed research-method-card">
          <div class="study-card-header">
            <span class="research-method-label">Analytics</span>
            <span class="study-card-tag">Data</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Metric</span>
              Clicks from app open to desired page, with and without search
            </li>
            <li>
              <span class="study-card-category">Finding</span>
              Too many clicks to reach content, search rarely used due to poor experience
            </li>
          </ul>
          <div class="research-method-finding research-method-finding--chart">
            <div class="chart-wrap">
              <div class="chart-area">
                <div class="chart-grid">
                  <div class="chart-grid-line"><span class="chart-grid-line-label">6</span></div>
                  <div class="chart-grid-line"><span class="chart-grid-line-label">4</span></div>
                  <div class="chart-grid-line"><span class="chart-grid-line-label">2</span></div>
                  <div class="chart-grid-line"><span class="chart-grid-line-label">0</span></div>
                </div>
                <div class="chart-bars">
                  <div class="chart-bar-group">
                    <div class="chart-bar chart-bar--without" style="--h: 70%;">
                      <div class="chart-bar-inner chart-bar--with" style="--inner-h: 85.71%;"></div>
                    </div>
                  </div>
                  <div class="chart-bar-group">
                    <div class="chart-bar chart-bar--without" style="--h: 60%;">
                      <div class="chart-bar-inner chart-bar--with" style="--inner-h: 83.33%;"></div>
                    </div>
                  </div>
                  <div class="chart-bar-group">
                    <div class="chart-bar chart-bar--without" style="--h: 50%;">
                      <div class="chart-bar-inner chart-bar--with" style="--inner-h: 80%;"></div>
                    </div>
                  </div>
                  <div class="chart-bar-group">
                    <div class="chart-bar chart-bar--without" style="--h: 100%;">
                      <div class="chart-bar-inner chart-bar--with" style="--inner-h: 75%;"></div>
                    </div>
                  </div>
                </div>
                <div class="chart-x-labels">
                  <span>Tasks</span>
                  <span>Crops</span>
                  <span>Metrics</span>
                  <span>Reports</span>
                </div>
              </div>
            </div>
            <div class="chart-legend">
              <span class="chart-legend-item chart-legend-item--without">Without search</span>
              <span class="chart-legend-item chart-legend-item--with">With search</span>
            </div>
            <p class="chart-title">Clicks to destination</p>
          </div>
        </div>
        <div class="slide-stagger-item study-card study-card--dashed research-method-card">
          <div class="study-card-header">
            <span class="research-method-label">Sales Meetings</span>
            <span class="study-card-tag">Feedback</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Channel</span>
              Weekly sales meetings surfacing demo feedback and feature requests
            </li>
            <li>
              <span class="study-card-category">Signal</span>
              Search came up constantly as a pain point across client types
            </li>
          </ul>
          <div class="research-method-finding research-method-finding--quote">
            <p class="study-quote">
              &ldquo;Every account I'm talking to has brought up how many things they need to track, but they can't
              figure out how to find them.&rdquo;
            </p>
            <p class="study-cite">Sales rep, weekly feedback sync</p>
          </div>
        </div>

        <div class="slide-stagger-item study-card study-card--dashed research-method-card">
          <div class="study-card-header">
            <span class="research-method-label">Farm Visits</span>
            <span class="study-card-tag">Interviews</span>
          </div>
          <ul class="study-card-list">
            <li>
              <span class="study-card-category">Setting</span>
              On-site with owners, managers, and team leaders using the product in context
            </li>
            <li>
              <span class="study-card-category">Focus</span>
              How users navigated the platform to find the content they needed
            </li>
          </ul>
          <div class="research-method-finding">
            <Image
              src={farmVisit}
              width={600}
              alt="Farm visit: team reviewing information on laptop"
              layout="constrained"
              fit="cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 5: Scoping the Data -->
  <section class="study-slide slide-data" id="data">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-text">
        <div class="slide-header">
          <p class="slide-section-label slide-body">Strategy</p>
          <h2 class="slide-heading">Scoping the Data</h2>
          <p class="slide-body slide-subtitle">
            To better inform design exploration, I worked with a backend engineer to create example JSON payloads for
            our system's data types
          </p>
        </div>
      </div>
      <div class="comparison-slider" data-comparison-slider>
        <div class="comparison-side comparison-side--json">
          <div class="comparison-label">Data Model</div>
          <div class="comparison-columns">
            {
              dataColumns.map((col) => (
                <div class="comparison-column">
                  <div class="comparison-column-label">{col.label}</div>
                  <pre class="comparison-code">
                    <code set:html={highlightJson(col.data)} />
                  </pre>
                </div>
              ))
            }
          </div>
        </div>
        <div class="comparison-side comparison-side--ui" style="--clip-position: 50%">
          <div class="comparison-label">Application</div>
          <Image
            src={artemisPages}
            alt="Artemis application pages showing farm management interfaces"
            width={1200}
            layout="constrained"
          />
        </div>
        <div class="comparison-handle" style="--handle-position: 50%">
          <div class="comparison-handle-line"></div>
          <div class="comparison-handle-grip">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M8 6l-4 6 4 6M16 6l4 6-4 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="comparison-handle-line"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 6: Design Exploration -->
  <section class="study-slide slide-exploration" id="exploration">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Execution</p>
        <h2 class="slide-heading">Design Exploration</h2>
        <p class="slide-body slide-subtitle">
          Early explorations tested different approaches to layout, result types, and interaction patterns before
          converging on a direction
        </p>
      </div>
      <div class="exploration-scroll">
        <div class="exploration-row">
          <div class="exploration-item">
            <div class="exploration-media">
              <video autoplay loop muted playsinline>
                <source src="/assets/videos/artemis/artemis-farm-page-search.webm" type="video/webm" />
              </video>
            </div>
            <div class="exploration-content">
              <span class="exploration-kept exploration-kept--no">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
                >
                Cut
              </span>
              <h3 class="exploration-title">Page vs Farm Search</h3>
              <p class="exploration-description">
                Users would often get confused between in-page search and searching the whole farm, I experimented with
                only having one search that could toggle between searching the page or everything.
              </p>
            </div>
          </div>

          <div class="exploration-item">
            <div class="exploration-media">
              <video autoplay loop muted playsinline>
                <source src="/assets/videos/artemis/artemis-full-page-search.webm" type="video/webm" />
              </video>
            </div>
            <div class="exploration-content">
              <span class="exploration-kept exploration-kept--no">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
                >
                Cut
              </span>
              <h3 class="exploration-title">Full Page Modal</h3>
              <p class="exploration-description">
                Since we were sticking with searching the whole farm, I tried sticking with the existing full-page
                experience but with benefits of modal behavior.
              </p>
            </div>
          </div>

          <div class="exploration-item">
            <div class="exploration-media">
              <Image src={searchWidgets} width={480} alt="Search widgets concept" layout="constrained" fit="cover" />
            </div>
            <div class="exploration-content">
              <span class="exploration-kept exploration-kept--no">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
                >
                Cut
              </span>
              <h3 class="exploration-title">Search Widgets</h3>
              <p class="exploration-description">
                What if a user just wanted a quick glance at one metric? Inline data components could save the user from
                having to leave the page at all.
              </p>
            </div>
          </div>

          <div class="exploration-item">
            <div class="exploration-media">
              <video autoplay loop muted playsinline>
                <source src="/assets/videos/artemis/artemis-tab-search.webm" type="video/webm" />
              </video>
            </div>
            <div class="exploration-content">
              <span class="exploration-kept exploration-kept--yes">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                Kept
              </span>
              <h3 class="exploration-title">Tabbed Search</h3>
              <p class="exploration-description">
                With the multitude of different data types that could potentially appear for a given search input, I had
                to come up with ways to help the user narrow down the results.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Slide 7: Results -->
  <section class="study-slide slide-results" id="results">
    <div class="slide-inner slide-inner--centered">
      <div class="slide-header">
        <p class="slide-section-label slide-body">Outcomes</p>
        <h2 class="slide-heading">Results</h2>
        <p class="slide-body slide-subtitle results-subtitle">Search became the front door to the entire platform</p>
      </div>
      <div class="results-cards">
        <div class="slide-stagger-item study-viz-card">
          <div class="study-viz-card-viz result-card-viz">
            <div class="cursor-click-scene">
              <div class="cursor-click-btn">
                <svg
                  class="cursor-click-btn-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><circle cx="11" cy="11" r="7"></circle><line x1="16.5" y1="16.5" x2="21" y2="21"></line></svg
                >
              </div>
              <svg class="cursor-click-cursor" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M5 3l14 10.5-6.5 1.5-3.5 6z"
                  fill="var(--study-heading)"
                  stroke="white"
                  stroke-width="1.5"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
          </div>
          <div class="study-viz-card-content">
            <div class="study-viz-card-number">01</div>
            <h3 class="study-viz-card-title">Most Used Feature</h3>
            <p class="study-viz-card-body">
              Within weeks of launch it was one of the most frequently used features, often the first thing users
              clicked when opening the app.
            </p>
          </div>
        </div>
        <div class="slide-stagger-item study-viz-card">
          <div class="study-viz-card-viz result-card-viz">
            <div class="fewer-clicks-chart" data-fewer-clicks-chart>
              <div class="chart-wrap">
                <div class="chart-area">
                  <div class="chart-grid">
                    <div class="chart-grid-line"><span class="chart-grid-line-label">6</span></div>
                    <div class="chart-grid-line"><span class="chart-grid-line-label">4</span></div>
                    <div class="chart-grid-line"><span class="chart-grid-line-label">2</span></div>
                    <div class="chart-grid-line"><span class="chart-grid-line-label">0</span></div>
                  </div>
                  <div class="chart-bars">
                    <div class="chart-bar-group">
                      <div class="chart-bar chart-bar--without" data-from="70%" data-to="53%" style="--h: 70%;">
                        <div
                          class="chart-bar-inner chart-bar--with"
                          data-from="85.71%"
                          data-to="69.8%"
                          style="--inner-h: 85.71%;"
                        >
                        </div>
                      </div>
                    </div>
                    <div class="chart-bar-group">
                      <div class="chart-bar chart-bar--without" data-from="60%" data-to="43%" style="--h: 60%;">
                        <div
                          class="chart-bar-inner chart-bar--with"
                          data-from="83.33%"
                          data-to="76.7%"
                          style="--inner-h: 83.33%;"
                        >
                        </div>
                      </div>
                    </div>
                    <div class="chart-bar-group">
                      <div class="chart-bar chart-bar--without" data-from="50%" data-to="37%" style="--h: 50%;">
                        <div
                          class="chart-bar-inner chart-bar--with"
                          data-from="80%"
                          data-to="89.2%"
                          style="--inner-h: 80%;"
                        >
                        </div>
                      </div>
                    </div>
                    <div class="chart-bar-group">
