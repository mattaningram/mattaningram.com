---
import BaseLayout from '@layouts/BaseLayout.astro'
import Header from '@components/Header.astro'
import ResumeItem from '@components/resume/ResumeItem.astro'
import { getCollection, render } from 'astro:content'
import { Icon } from 'astro-icon/components'

const entries = await getCollection('resume')
const sorted = entries.sort((a, b) => a.data.order - b.data.order)

const rendered = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry)
    return { ...entry, Content }
  }),
)
---

<BaseLayout title="Resume — Mattan Ingram" pageColor="#306CDC" class="resume-body">
  <Header />
  <main class="resume-page">
    <div class="resume-doc">
      <header class="resume-section">
        <div class="resume-section__left">
          <h1 class="resume-header__name">Mattan Ingram</h1>
          <p class="resume-header__title">Product Designer</p>
        </div>
        <div class="resume-section__right">
          <a href="https://mattaningram.com" class="resume-header__link">mattaningram.com</a>
          <a href="mailto:mattaningram@gmail.com" class="resume-header__link">mattaningram@gmail.com</a>
        </div>
      </header>

      <a href="/assets/resume/Mattan Ingram Resume 2026.pdf" class="resume-pdf-btn" download>
        <Icon name="document" />
        Download PDF
      </a>

      <section class="resume-experience">
        {
          rendered.map(({ data, Content }) => (
            <ResumeItem
              name={data.name}
              position={data.position}
              dates={data.dates}
              url={data.url}
              color={data.color}
              icon={data.icon}
            >
              <Content />
            </ResumeItem>
          ))
        }
      </section>

      <section class="resume-section resume-education">
        <div class="resume-section__left">
          <h3 class="resume-education__name">Skidmore College</h3>
        </div>
        <div class="resume-section__right">
          <p><strong>Bachelor of Science</strong></p>
          <p>Communication Design</p>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style lang="scss" is:global>
  html:has(.resume-body) {
    background-color: white;
  }
</style>

<style lang="scss">
  @use '../styles/scssVariables' as *;

  .resume-page {
    display: flex;
    justify-content: center;
    padding: var(--spacing-16) var(--spacing-13);

    @media (width < $breakpoint-md) {
      padding: var(--spacing-10) var(--spacing-8);
    }

    @media print {
      padding: 0;
    }
  }

  .resume-doc {
    display: grid;
    width: 768px;
    max-width: 100%;
    gap: 80px;
  }

  :global(.resume-section) {
    position: relative;
    display: flex;
    align-items: flex-start;
    padding-inline: var(--spacing-6);

    @media (width < $breakpoint-md) {
      flex-direction: column;
      gap: var(--spacing-6);
    }
  }

  :global(.resume-section__left) {
    width: 256px;
    flex-shrink: 0;
  }

  :global(.resume-section__right) {
    flex: 1;
    display: flex;
    flex-direction: column;

    :global(p) {
      color: var(--gray-1);
      font-size: 0.875rem;
      line-height: 1.6;
      margin: 0;
      text-wrap: balance;
    }

    :global(strong) {
      font-weight: 600;
    }
  }

  .resume-header__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--gray-1);
    line-height: 1.3;
  }

  .resume-header__title {
    font-size: 16px;
    color: var(--gray-5);
    margin-top: 2px;
  }

  .resume-header__link {
    font-size: 0.875rem;
    color: var(--gray-5);
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }

  .resume-experience {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }

  .resume-education__name {
    font-size: 20px;
    font-weight: 700;
    color: #11181c;
    line-height: 1.3;
  }

  .resume-pdf-btn {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    color: var(--gray-5);
    font-size: 0.875rem;
    font-weight: 500;
    position: fixed;
    top: var(--page-gutter);
    right: var(--page-gutter);
    z-index: 10;
    padding: var(--spacing-4);
    border-radius: var(--spacing-2);
    min-height: 40px;
    backdrop-filter: blur(8px) brightness(1.15);
    transition: 0.2s ease-out;
    transition-property: color, background-color, transform;

    svg {
      font-size: 1.25rem;
    }

    @media print {
      display: none;
    }

    &:hover {
      color: var(--gray-1);
      background-color: white;
      transform: scale(1.05);
    }

    &:active {
      transform: scale(0.95);
    }
  }

  :global(.site-header) {
    @media print {
      display: none;
    }
  }
</style>
