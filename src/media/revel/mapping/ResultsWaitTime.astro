---
const { class: className, ...rest } = Astro.props
---

<div class:list={['viz-waittime', className]} {...rest} aria-hidden="true">
  <div class="viz-pickup-card">
    <div class="viz-pickup-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
    </div>
    <div class="viz-pickup-text">
      <span class="viz-pickup-label">Estimated pickup</span>
      <div class="viz-time-wrap">
        <span class="viz-time viz-time--before">8 min</span>
        <span class="viz-time viz-time--after">5 min</span>
      </div>
    </div>
  </div>
  <span class="viz-delta">&minus;3 min</span>
</div>

<style lang="scss">
  .viz-waittime {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-5);
  }

  .viz-pickup-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-5);
    padding: var(--spacing-5) var(--spacing-7);
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .viz-pickup-icon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: var(--study-text-muted);
    opacity: 0.5;
  }

  .viz-pickup-icon svg {
    width: 100%;
    height: 100%;
  }

  .viz-pickup-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .viz-pickup-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--study-text-muted);
    opacity: 0.6;
  }

  .viz-time-wrap {
    display: grid;
  }

  .viz-time {
    grid-area: 1 / 1;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .viz-time--before {
    color: var(--study-text-muted);
    animation: wait-before 6s ease-in-out infinite;
  }

  .viz-time--after {
    color: var(--study-color);
    animation: wait-after 6s ease-in-out infinite;
  }

  .viz-delta {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--study-color);
    animation: wait-delta 6s ease-in-out infinite;
  }

  @keyframes wait-before {
    0%, 30% { opacity: 1; }
    42%, 88% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes wait-after {
    0%, 30% { opacity: 0; }
    42%, 88% { opacity: 1; }
    100% { opacity: 0; }
  }

  @keyframes wait-delta {
    0%, 30% { opacity: 0; }
    42%, 88% { opacity: 1; }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .viz-time--before,
    .viz-time--after,
    .viz-delta {
      animation: none;
    }

    .viz-time--before {
      opacity: 0;
    }

    .viz-time--after {
      opacity: 1;
    }

    .viz-delta {
      opacity: 1;
    }
  }
</style>
