---
import BaseLayout from '@layouts/BaseLayout.astro'
import Logo from '@components/Logo.astro'
import StudyNav from '@components/StudyNav.astro'

export interface Props {
  title: string
  color: string
  slides: Array<{ id: string; title: string }>
}

const { title, color, slides } = Astro.props
---

<BaseLayout title={title} pageColor={color} class="study-layout">
  <nav class="study-header">
    <a class="study-home-link" href="/" aria-label="Home"><Logo size="1.5rem" /></a>
  </nav>

  <slot name="nav"><StudyNav slides={slides} /></slot>

  <main class="study-slides">
    <slot />
  </main>
</BaseLayout>

<script>
  import { animate, stagger, inView } from 'motion'

  const cleanups: (() => void)[] = []
  const animated = new WeakSet<Element>()
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  function initStudy() {
    cleanup()

    const container = document.querySelector('.study-slides') as HTMLElement
    if (!container) return

    const sections = Array.from(container.querySelectorAll(':scope > section')) as HTMLElement[]
    const dots = document.querySelectorAll('.study-nav-dot')

    // --- Active slide tracking via IntersectionObserver ---
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const index = sections.indexOf(entry.target as HTMLElement)
            dots.forEach((dot, i) => dot.classList.toggle('active', i === index))

            const id = (entry.target as HTMLElement).id
            if (id) history.replaceState(null, '', `#${id}`)
          }
        }
      },
      { root: container, threshold: 0.5 },
    )

    sections.forEach((s) => observer.observe(s))
    cleanups.push(() => observer.disconnect())

    // --- Dot nav click handling (smooth scroll within container) ---
    dots.forEach((dot) => {
      const handler = (e: Event) => {
        e.preventDefault()
        const href = (dot as HTMLAnchorElement).getAttribute('href')
        if (!href) return
        const target = document.querySelector(href) as HTMLElement
        target?.scrollIntoView({ behavior: 'smooth' })
      }
      dot.addEventListener('click', handler)
      cleanups.push(() => dot.removeEventListener('click', handler))
    })

    // --- Per-slide entrance animations via inView ---
    sections.forEach((section) => {
      if (animated.has(section)) return

      if (reducedMotion) {
        // Show everything immediately
        section.querySelectorAll('.slide-heading, .slide-body, .slide-media, .slide-stagger-item').forEach((el) => {
          ;(el as HTMLElement).style.opacity = '1'
        })
        animated.add(section)
        return
      }

      const stop = inView(
        section,
        () => {
          if (animated.has(section)) return
          animated.add(section)
          animateSlide(section)
        },
        { amount: 0.25 },
      )
      cleanups.push(stop)
    })

    // --- Keyboard navigation ---
    const onKeyDown = (e: KeyboardEvent) => {
      // Don't intercept if user is in an input or modifier keys are pressed
      if (e.target !== document.body || e.metaKey || e.ctrlKey) return

      let currentIndex = 0
      for (let i = 0; i < sections.length; i++) {
        const rect = sections[i].getBoundingClientRect()
        const containerRect = container.getBoundingClientRect()
        if (rect.top >= containerRect.top - 10) {
          currentIndex = i
          break
        }
      }

      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
        e.preventDefault()
        const next = Math.min(currentIndex + 1, sections.length - 1)
        sections[next]?.scrollIntoView({ behavior: 'smooth' })
      } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
        e.preventDefault()
        const prev = Math.max(currentIndex - 1, 0)
        sections[prev]?.scrollIntoView({ behavior: 'smooth' })
      }
    }
    document.addEventListener('keydown', onKeyDown)
    cleanups.push(() => document.removeEventListener('keydown', onKeyDown))

    // --- Handle initial hash ---
    const hash = window.location.hash
    if (hash) {
      const target = document.querySelector(hash) as HTMLElement
      if (target && sections.includes(target)) {
        requestAnimationFrame(() => target.scrollIntoView({ behavior: 'instant' }))
      }
    }
  }

  function animateSlide(section: HTMLElement) {
    const easing: [number, number, number, number] = [0.22, 1, 0.36, 1]

    const heading = section.querySelector('.slide-heading') as HTMLElement
    const bodies = section.querySelectorAll('.slide-body')
    const media = section.querySelector('.slide-media') as HTMLElement
    const items = section.querySelectorAll('.slide-stagger-item')

    if (heading) {
      animate(heading, { opacity: [0, 1], y: [24, 0] } as any, { duration: 0.6, easing } as any)
    }

    if (bodies.length > 0) {
      animate(
        bodies,
        { opacity: [0, 1], y: [16, 0] } as any,
        { duration: 0.6, delay: stagger(0.1, { start: 0.15 } as any), easing } as any,
      )
    }

    if (media) {
      animate(
        media,
        { opacity: [0, 1], y: [20, 0], scale: [0.97, 1] } as any,
        { duration: 0.7, delay: 0.25, easing } as any,
      )
    }

    if (items.length > 0) {
      animate(
        items,
        { opacity: [0, 1], y: [12, 0] } as any,
        { duration: 0.4, delay: stagger(0.1, { start: 0.2 } as any), easing } as any,
      )
    }
  }

  function cleanup() {
    cleanups.forEach((fn) => fn())
    cleanups.length = 0
  }

  // Init on load and Astro view transitions
  initStudy()
  document.addEventListener('astro:after-swap', initStudy)
  document.addEventListener('astro:before-swap', cleanup)
</script>

<style lang="scss">
  @use '../styles/scssVariables' as *;

  :global(body.study-layout) {
    --study-color: var(--page-color);
    --study-bg: #fafafa;
    --study-bg-alt: #f0f0f0;
    --study-text: #1a1a2e;
    --study-text-muted: #6b7280;
    --study-heading: #0f172a;
    --study-border: #e0e0e0;

    background-color: var(--study-bg);
    color: var(--study-text);
  }

  .study-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    padding: var(--spacing-7);
    mix-blend-mode: difference;
  }

  .study-home-link {
    display: block;
    width: fit-content;
  }

  .study-slides {
    height: 100dvh;
    overflow-y: auto;
    scroll-snap-type: y mandatory;

    @media (width <style $breakpoint-md) {
      height: auto;
      overflow-y: visible;
      scroll-snap-type: none;
    }
  }
</style>

<style lang="scss" is:global>
  @use '../styles/scssVariables' as *;

  .study-slide {
    min-height: 100dvh;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-12);
    overflow: hidden;
    position: relative;

    @media (width < $breakpoint-lg) {
      padding: var(--spacing-10) var(--spacing-12);
    }

    @media (width < $breakpoint-md) {
      min-height: auto;
      scroll-snap-align: none;
      padding: var(--spacing-14) var(--spacing-8);
    }

    @media (width < $breakpoint-sm) {
      padding: var(--spacing-12) var(--spacing-6);
    }
  }

  // --- Animation initial states (hidden until animated) ---

  .slide-heading,
  .slide-body,
  .slide-media,
  .slide-stagger-item {
    opacity: 0;
  }

  // ========================================
  // Shared study card styles
  // ========================================

  .study-card {
    border: 1.5px solid var(--study-border);
    border-radius: 12px;
    overflow: hidden;

    &--dashed {
      border-style: dashed;
      background-color: white;
    }

    &--filled {
      border-color: var(--study-color);
      background-color: var(--study-color);
    }
  }

  .study-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding: var(--spacing-7) var(--spacing-8) var(--spacing-6);
  }

  .study-card-tag {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
    border: 1px solid #aaa;
    border-radius: 4px;
    padding: 2px 6px;

    .study-card--filled & {
      color: rgba(255, 255, 255, 0.85);
      border-color: rgba(255, 255, 255, 0.4);
      background-color: rgba(255, 255, 255, 0.15);
    }
  }

  .study-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;

    li {
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--study-heading);
      display: grid;
      grid-template-columns: 5.5rem 1fr;
      gap: var(--spacing-6);
      align-items: baseline;
      border-top: 1px dashed var(--study-border);
      padding: var(--spacing-6) var(--spacing-8);
      text-wrap: balance;

      .study-card--filled & {
        color: #fff;
        border-top-style: solid;
        border-top-color: rgba(255, 255, 255, 0.2);
      }
    }
  }

  .study-card-category {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #666;

    .study-card--filled & {
      color: rgba(255, 255, 255, 0.7);
    }
  }

  .slide-subtitle {
    max-width: 52ch;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.6;
    color: var(--study-text-muted);
    font-weight: 500;
    margin-top: var(--spacing-8);
    text-wrap: balance;
  }

  // ========================================
  // Shared viz card styles (result / decision cards)
  // ========================================

  .study-viz-card {
    text-align: left;
    background: white;
    border: 1px solid var(--study-border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
  }

  .study-viz-card-viz {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-6);
    background: hsl(from var(--study-color) h s l / 0.03);
    border-bottom: 1px solid var(--study-border);
    border-radius: 11px 11px 0 0;
  }

  .study-viz-card-content {
    padding: var(--spacing-8);
  }

  .study-viz-card-number {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--study-color);
    letter-spacing: 0.05em;
    width: 28px;
    height: 28px;
    display: grid;
    place-content: center;
    border-radius: 50%;
    background: hsl(from var(--study-color) h s l / 0.1);
    flex-shrink: 0;
    margin-bottom: var(--spacing-3);
  }

  .study-viz-card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--study-heading);
    margin-bottom: var(--spacing-6);
  }

  .study-viz-card-body {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--study-text-muted);
  }

  // ========================================
  // Shared quote styles
  // ========================================

  .study-quote {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.55;
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--study-text);
    margin: 0;
  }

  .study-cite {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--study-text-muted);
    margin: 0;
  }
</style>
